# SiliconFlow API Configuration
# Copy this file to .env and fill in your API keys
# NEVER commit .env to version control!

# SiliconFlow (国内大模型平台)
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
DEFAULT_MODEL=Kwai-Kolors/Kolors
DEFAULT_SIZE=1024x1024
DEFAULT_SEED=42

# Zhipu AI (智谱 AI)
ZHIPU_API_KEY=your_zhipu_api_key_here

# ModelScope (魔搭社区)
# Register at https://www.modelscope.cn
# Get API key from: 个人中心 -> 访问令牌
# IMPORTANT: The API key format is 'ms-xxxxx', but when using it,
# you should remove the 'ms-' prefix in the Authorization header
MODELSCOPE_API_KEY=your_modelscope_api_key_here
MODELSCOPE_BASE_URL=https://api-inference.modelscope.cn/v1

# ModelScope Model IDs
# - black-forest-labs/FLUX.1-Krea-dev (高质量, 细节丰富)
# - black-forest-labs/FLUX.1-dev
# - Qwen/Qwen-Image (通义万相, 中文理解强)
# - ZhipuAI/Z-Image-Turbo (阿里通义实验室, 每日免费2000张)
MODELSCOPE_DEFAULT_MODEL=black-forest-labs/FLUX.1-Krea-dev

# Alibaba Cloud DashScope (阿里云灵积)
# Register at https://dashscope.aliyun.com
# Get API key from: 控制台 -> API Key 管理
# 通义万相 (wanx-v1) 支持多种风格:
# - <chinese painting> 中国画
# - <anime> 动漫
# - <oil painting> 油画
# - <watercolor> 水彩
# - <sketch> 素描
# - <photography> 摄影
# 新用户赠送免费额度，具体查看控制台
DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1

# Volcengine (火山引擎) Ark
# Register at https://console.volcengine.com/ark
# Get API key from: 控制台 -> API Key 管理
# 需要先开通模型服务才能使用:
# - doubao-seedream-4-0-250828 (文生图)
# - doubao-seedream-4-5-251128 (更高质量)
# - doubao-seedream-5-0-260128 (最新版)
VOLCENGINE_API_KEY=your_volcengine_api_key_here
VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VOLCENGINE_DEFAULT_MODEL=doubao-seedream-4-0-250828

# Security: This file should have permissions 600 (chmod 600 .env)
# Only the owner should be able to read/write it
