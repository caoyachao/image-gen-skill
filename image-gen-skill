def compare_apis_for_requirements(directions: dict) -> dict:
    """
    比较各API优势，返回详细对比供用户决策
    这是 C003 约束的实现
    """
    print("\n" + "="*60)
    print("  🔧 API 对比分析 (强制步骤)")
    print("="*60)
    
    # 根据需求评分
    scores = {'siliconflow': 0, 'zhipu': 0, 'modelscope': 0}
    reasons = {'siliconflow': [], 'zhipu': [], 'modelscope': []}
    
    style = directions.get('style')
    has_chinese = any('\u4e00' <= c <= '\u9fff' for c in directions.get('description', ''))
    
    # 风格评分
    if style == 'realistic':
        scores['siliconflow'] += 2
        scores['modelscope'] += 2  # FLUX.1 也很擅长写实
        reasons['siliconflow'].append("写实风格 Kolors 照片级真实感更强")
        reasons['modelscope'].append("FLUX.1 高质量写实，细节丰富")
    elif style == 'illustration':
        scores['zhipu'] += 2
        scores['modelscope'] += 1
        reasons['zhipu'].append("插画风格 CogView 艺术表达更好")
        reasons['modelscope'].append("FLUX.1 艺术风格表现力强")
    elif style in ['cinematic', 'concept', 'oil_painting']:
        scores['modelscope'] += 2
        reasons['modelscope'].append("艺术/电影风格 FLUX.1 质量更高")
    
    # 语言评分
    if has_chinese:
        scores['zhipu'] += 1
        reasons['zhipu'].append("中文提示词 CogView 理解更准确")
    
    # 打印对比表
    print("\n📊 能力对比:")
    print("-" * 60)
    for api_key, api in APIS.items():
        score = scores[api_key]
        print(f"\n{api['name']}")
        print(f"   当前场景匹配度: {'⭐' * (score + 1)}")
        print(f"   擅长: {', '.join(api['best_for'][:2])}")
        print(f"   优势: {', '.join(api['strengths'][:2])}")
        print(f"   劣势: {', '.join(api['weaknesses'][:1])}")
        if reasons[api_key]:
            print(f"   ✓ 适合原因: {reasons[api_key][0]}")
    print("-" * 60)
    
    # 推荐但不强制
    best = max(scores, key=scores.get)
    print(f"\n💡 系统推荐: {APIS[best]['name']}")
    print(f"   (但你可以根据偏好选择其他)")
    
    return {'scores': scores, 'reasons': reasons, 'recommendation': best}

