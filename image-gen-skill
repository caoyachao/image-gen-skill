def interactive_mode():
    """
    强制交互式向导 - 唯一合法的生成入口
    实现 C001 + C002 + C003 约束
    """
    print("\n" + "="*60)
    print("  🎨 Image-Gen-Skill 图像生成向导")
    print("="*60)
    print("\n本向导强制执行以下设计约束:")
    for c in CONSTRAINTS.values():
        print(f"   {c['id']}: {c['description']}")
    print("="*60 + "\n")
    
    # Step 1: 自由描述 (C002 - 起点)
    print("【步骤 1/5】自由描述")
    print("请描述你想要的图像，可以是具体的也可以是模糊的。")
    print("例如: 'Jeanne de Lamare的肖像', '夕阳下的海边小镇'\n")
    
    description = input("💭 描述: ").strip()
    if not description:
        raise ConstraintViolation("❌ 必须提供描述才能继续")
    
    # Step 2: 风格确认 (C002)
    print("\n【步骤 2/5】风格选择")
    styles = [
        ('realistic', '写实/照片级', '像照片一样真实'),
        ('illustration', '插画/手绘', '艺术化、绘画感'),
        ('cinematic', '电影感', '戏剧性光影、电影色调'),
        ('concept', '概念设计', '设计图、概念艺术'),
        ('oil_painting', '油画风格', '古典油画质感'),
    ]
    for i, (k, n, d) in enumerate(styles, 1):
        print(f"   {i}. {n} - {d}")
    
    while True:
        choice = input("\n选择风格 [1-5]: ").strip()
        if choice.isdigit() and 1 <= int(choice) <= 5:
            style = styles[int(choice)-1][0]
            break
        print("请输入有效选项")
    
    # Step 3: 构图确认 (C002)
    print("\n【步骤 3/5】构图选择")
    angles = [
        ('close-up', '特写', '面部细节为主'),
        ('medium', '中景/半身', '人物+部分环境'),
        ('wide', '广角/全身', '完整人物+环境'),
    ]
    for i, (k, n, d) in enumerate(angles, 1):
        print(f"   {i}. {n} - {d}")
    
    while True:
        choice = input("\n选择构图 [1-3]: ").strip()
        if choice.isdigit() and 1 <= int(choice) <= 3:
            angle = angles[int(choice)-1][0]
            break
        print("请输入有效选项")
    
    # Step 4: 氛围确认 (C002)
    print("\n【步骤 4/5】氛围选择")
    moods = [
        ('melancholic', '忧郁/感伤', 'Jeanne式的悲剧氛围'),
        ('warm', '温暖/柔和', '舒适、亲切'),
        ('dramatic', '戏剧性', '强烈对比、冲击'),
        ('serene', '宁静/安详', '平和、淡然'),
    ]
    for i, (k, n, d) in enumerate(moods, 1):
        print(f"   {i}. {n} - {d}")
    
    while True:
        choice = input("\n选择氛围 [1-4]: ").strip()
        if choice.isdigit() and 1 <= int(choice) <= 4:
            mood = moods[int(choice)-1][0]
            break
        print("请输入有效选项")
    
    # Step 5: 必需要素 (C002)
    print("\n【步骤 5/5】必需要素")
    print("有什么是你必须坚持的元素？(直接回车结束)")
    must_haves = []
    prompts = [
        "特定颜色或材质? (如: 必须是蓝色连衣裙)",
        "特定物品或装饰? (如: 必须有珍珠耳坠)",
        "特定光线或时间? (如: 必须是黄昏光线)",
    ]
    for p in prompts:
        ans = input(f"   {p} ").strip()
        if ans:
            must_haves.append(ans)
    
    # 汇总用户大方向 (C001 - 用户确认)
    directions = {
        'description': description,
        'style': style,
        'angle': angle,
        'mood': mood,
        'must_haves': must_haves,
    }
    
    print("\n" + "="*60)
    print("  📋 请确认你的选择")
    print("="*60)
    print(f"   描述: {description}")
    print(f"   风格: {style}")
    print(f"   构图: {angle}")
    print(f"   氛围: {mood}")
    if must_haves:
        print(f"   必需要素: {', '.join(must_haves)}")
    print("="*60)
    
    confirm = input("\n确认以上大方向？(y/n/修改) [y]: ").strip().lower()
    if confirm == 'n':
        print("已取消。请重新运行向导。")
        return
    elif confirm == '修改':
        print("\n重新启动向导...\n")
        return interactive_mode()
    
    # C003: 强制API比较
    api_comparison = compare_apis_for_requirements(directions)
    
    print("\n请选择 API:")
    for i, (k, api) in enumerate(APIS.items(), 1):
        print(f"   {i}. {api['name']}")
    print(f"   0. 接受系统推荐 ({APIS[api_comparison['recommendation']]['name']})")
    
    while True:
        choice = input(f"\n选择 [0-{len(APIS)}]: ").strip()
        if choice == '0':
            selected_api = api_comparison['recommendation']
            break
        elif choice.isdigit() and 1 <= int(choice) <= len(APIS):
            selected_api = list(APIS.keys())[int(choice)-1]
            break
        print("请输入有效选项")
    
    print(f"\n✅ 已选择: {APIS[selected_api]['name']}")
    
    # AI 增强细节 (在约束框架内)
    print("\n🤖 AI 正在基于你的选择补充专业细节...")
    
    # 构建最终提示词
    parts = [description]
    
    style_map = {
        'realistic': 'photorealistic, highly detailed, 8k',
        'illustration': 'digital illustration, artistic, clean lines',
        'cinematic': 'cinematic lighting, color grading, film look',
        'concept': 'concept art, detailed, professional',
        'oil_painting': 'oil painting style, classical art, canvas texture',
    }
    if style in style_map:
        parts.append(style_map[style])
    
    angle_map = {
        'close-up': 'close-up portrait, shallow depth of field',
        'medium': 'medium shot, balanced composition',
        'wide': 'wide angle, full body, environmental context',
    }
    if angle in angle_map:
        parts.append(angle_map[angle])
    
    mood_map = {
        'melancholic': 'melancholic atmosphere, soft shadows, introspective mood',
        'warm': 'warm tones, cozy atmosphere, golden lighting',
        'dramatic': 'dramatic lighting, high contrast, intense',
        'serene': 'serene atmosphere, soft lighting, peaceful',
    }
    if mood in mood_map:
        parts.append(mood_map[mood])
    
    if must_haves:
        parts.extend(must_haves)
    
    final_prompt = ", ".join(parts)
    
    print("\n" + "="*60)
    print("  📋 最终提示词")
    print("="*60)
    print(final_prompt)
    print("="*60)
    
    # 最终确认
    final_confirm = input("\n🚀 确认生成？(y/n) [y]: ").strip().lower()
    if final_confirm == 'n':
        print("已取消")
        return
    
    # 执行生成
    seed = input("随机种子 (回车随机): ").strip()
    seed = int(seed) if seed.isdigit() else None
    
    print(f"\n🎨 使用 {APIS[selected_api]['name']} 生成...")
    
    if selected_api == 'volcengine':
        from generate_doubao import generate_doubao_image, download_image
        import os
        result = generate_doubao_image(os.environ.get('VOLCENGINE_API_KEY'), final_prompt, model='doubao-seedream-4-0-250828', size='1024x1024')
        if result and 'data' in result:
            image_url = result['data'][0].get('url')
            if image_url:
                from pathlib import Path
                from datetime import datetime
                today = datetime.now().strftime('%Y%m%d')
                output_dir = Path('/root/.openclaw/workspace/agents/designer/output') / f'doubao_{today}'
                output_dir.mkdir(parents=True, exist_ok=True)
                output_path = output_dir / f'doubao_image_{seed or "001"}.png'
                if download_image(image_url, output_path):
                    print(f"✅ 已保存: {output_path}")
    elif selected_api == 'siliconflow':
        from generate import generate_image
        generate_image(final_prompt, '1024x1024', seed)
    elif selected_api == 'modelscope':
        from generate_modelscope import generate_image
        generate_image(final_prompt, '1024x1024', seed, model='black-forest-labs/FLUX.1-Krea-dev')
    elif selected_api == 'dashscope':
        from generate_aliyun import generate_aliyun_image, check_task_status, download_image
        import time
        result = generate_aliyun_image(os.environ.get('DASHSCOPE_API_KEY'), final_prompt, '1024x1024')
        if result and 'output' in result:
            task_id = result['output'].get('task_id')
            # Wait for async completion
            for i in range(24):  # Max 120s
                time.sleep(5)
                status = check_task_status(os.environ.get('DASHSCOPE_API_KEY'), task_id)
                if status and status.get('output', {}).get('task_status') == 'SUCCEEDED':
                    image_url = status['output']['results'][0].get('url')
                    if image_url:
                        from pathlib import Path
                        from datetime import datetime
                        today = datetime.now().strftime('%Y%m%d')
                        output_dir = Path('/root/.openclaw/workspace/agents/designer/output') / f'aliyun_{today}'
                        output_dir.mkdir(parents=True, exist_ok=True)
                        output_path = output_dir / f'aliyun_image_{seed or "001"}.png'
                        if download_image(image_url, output_path):
                            print(f"✅ 已保存: {output_path}")
                    break
    else:
        from generate_zhipu import generate_image
        generate_image(final_prompt, '1024x1024', seed)

# =============================================================================
# 主入口 (强制执行约束)
# =============================================================================

def main():
    parser = argparse.ArgumentParser(
        description='Image-Gen-Skill - Constrained Image Generator',
        epilog='注意: 本skill强制执行设计约束，必须使用 --interactive 模式'
    )
    
    parser.add_argument('--interactive', '-i', action='store_true', 
                       help='启动交互式向导 (必需)')
    parser.add_argument('--prompt', '-p', help='❌ 禁用: 必须使用交互模式')
    parser.add_argument('--quick', '-q', action='store_true', 
                       help='❌ 禁用: 快速模式已移除')
    
    args = parser.parse_args()
    
    # C001 约束: 强制交互模式
    if args.prompt or args.quick:
        enforce_constraint('NO_DIRECT_GENERATE', False)
    
    if not args.interactive:
        print("\n" + "="*60)
        print("  ⚠️  必须使用交互式模式")
        print("="*60)
        print("\n这是设计约束 C001 的要求:")
        print("   禁止无用户确认直接生成")
        print("\n正确用法:")
        print("   image-gen-skill --interactive")
        print("   或")
        print("   image-gen-skill -i")
        print("="*60 + "\n")
        sys.exit(1)
    
    try:
        interactive_mode()
    except ConstraintViolation as e:
        print(f"\n约束检查失败: {e}")
        sys.exit(1)

if __name__ == '__main__':
    main()