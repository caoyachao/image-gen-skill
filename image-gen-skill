# 强制约束系统 (Mandatory Constraints)
# =============================================================================

CONSTRAINTS = {
    'NO_DIRECT_GENERATE': {
        'id': 'C001',
        'description': '禁止无用户确认直接生成',
        'rule': '必须使用交互式向导，逐项确认风格、构图、细节',
        'error_msg': '❌ 约束违反 C001: 必须使用 --interactive 模式，不能直接生成'
    },
    'NO_VAGUE_PROMPT': {
        'id': 'C002', 
        'description': '禁止未明确细节直接生成',
        'rule': '必须完成风格、构图、氛围、必需要素四步确认',
        'error_msg': '❌ 约束违反 C002: 细节未明确，无法生成'
    },
    'NO_RANDOM_API': {
        'id': 'C003',
        'description': '禁止未比较模型优势直接选择',
        'rule': '必须向用户说明各API优势并获得确认',
        'error_msg': '❌ 约束违反 C003: 必须比较API优势后由用户确认'
    }
}

class ConstraintViolation(Exception):
    """约束违反异常"""
    pass

def enforce_constraint(constraint_id: str, condition: bool):
    """强制执行约束，违反则抛出异常"""
    if not condition:
        c = CONSTRAINTS[constraint_id]
        print(f"\n{'='*60}")
        print(f"  生成被阻止")
        print(f"{'='*60}")
        print(f"\n{c['error_msg']}")
        print(f"\n📋 约束详情:")
        print(f"   ID: {c['id']}")
        print(f"   描述: {c['description']}")
        print(f"   规则: {c['rule']}")
        print(f"\n💡 正确做法:")
        print(f"   使用: image-gen-skill --interactive")
        print(f"{'='*60}\n")
        raise ConstraintViolation(c['error_msg'])

